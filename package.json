{
  "name": "wes-frontend",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "P9 WES 前端项目 - 休斯顿智能仓储执行系统",
  "scripts": {
    "dev": "vite",
    "build": "vite build --mode production",
    "build:dev": "vite build --mode development",
    "preview": "vite preview",
    "bootstrap": "pnpm install",
    "type:check": "vue-tsc --noEmit",
    "lint:eslint": "eslint --cache --max-warnings 0 \"./**/*.{ts,tsx,vue}\" --fix",
    "lint:prettier": "prettier --ignore-unknown --check --cache --write \"./**/*.{vue,tsx,less,scss}\"",
    "lint:stylelint": "stylelint \"./**/*.{vue,less,scss,css}\" --fix --cache --cache-location node_modules/.cache/stylelint/",
    "lint:all": "pnpm run type:check && pnpm run lint:eslint && pnpm run lint:prettier && pnpm run lint:stylelint",
    "lint": "pnpm run lint:all",
    "check": "pnpm run type:check && pnpm run lint"
  },
  "dependencies": {
    "@vueuse/core": "^12.8.2",
    "alova": "^3.2.10",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "element-plus": "^2.9.11",
    "lodash-es": "^4.17.21",
    "pinia": "^3.0.0",
    "pinia-plugin-persistedstate": "^4.2.0",
    "tailwind-merge": "^2.6.0",
    "vue": "^3.5.13",
    "vue-i18n": "^11.0.0-rc.1",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@iconify/vue": "^4.3.0",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.10.7",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/tsconfig": "^0.7.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.24.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.2.6",
    "eslint-plugin-vue": "^10.0.0",
    "globals": "^16.0.0",
    "postcss": "^8.4.49",
    "prettier": "^3.5.3",
    "sass-embedded": "^1.83.4",
    "stylelint": "^16.15.0",
    "stylelint-config-standard": "^37.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.29.1",
    "unplugin-auto-import": "^19.3.0",
    "unplugin-vue-components": "^31.0.0",
    "vite": "^6.0.5",
    "vite-plugin-vue-devtools": "^7.7.0",
    "vue-tsc": "^2.2.0"
  },
  "packageManager": "pnpm@10.10.0"
}
